# PBS job output files (stdout/stderr from HPC scheduler)
*.e[0-9][0-9][0-9][0-9][0-9][0-9][0-9]
*.o[0-9][0-9][0-9][0-9][0-9][0-9][0-9]

# Python cache
__pycache__/
*.pyc
*.pyo

# Model weights and large binaries
*.pth
*.zip
*.npz

# Virtual environment
.venv/

# Scratch / temp directories
.trash/
.codex
.agents/
.claude/

# Generated figures (produced by generate_*.py scripts)
figs/
*.png
*.svg
*.pdf

# Log files
*.log
completion_all_logs/
logs/

# Derived / intermediate data (too large for git)
derived/
inst_orig/

# Large dataset (stored separately on gdrive/HPC scratch)
dataset/

# Third-party repos (install separately)
repo/

# HPC PBS scheduler scripts (cluster-specific, not portable)
*.pbs

# Dissertation figure generation scripts (not part of the public pipeline)
generate_*.py
visualize_*.py
view_convonet_result.py

