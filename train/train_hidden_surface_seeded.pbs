#!/bin/bash
#PBS -N hs_seeded_train
#PBS -l select=1:ncpus=4:mem=32gb:ngpus=1
#PBS -l walltime=12:00:00
#PBS -q v1_gpu72

set -e
cd /rds/general/user/qp23/home/Hypo3D

source /rds/general/user/qp23/home/miniconda3/etc/profile.d/conda.sh
conda activate placeit3d
export LD_LIBRARY_PATH=/rds/general/user/qp23/home/miniconda3/envs/placeit3d/lib:$LD_LIBRARY_PATH

CONFIG=repo/scannet/hidden_surface/config_seeded.json
OUT_DIR=repo/scannet/completion/hidden_surface_seeded_out

echo "Training HiddenSurfaceSeededNet..."
echo "Config: ${CONFIG}"
echo "Output: ${OUT_DIR}"

python repo/scannet/hidden_surface/train_hidden_surface_seeded.py \
    ${CONFIG} \
    --exit-after 41400

echo "Done."
