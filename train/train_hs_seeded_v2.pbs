#!/bin/bash
#PBS -N train_hs_seeded_v2
#PBS -l select=1:ncpus=8:mem=32gb:ngpus=1:gpu_type=RTX6000
#PBS -l walltime=12:00:00
#PBS -q v1_gpu72

set -e
cd /rds/general/user/qp23/home/Hypo3D

source /rds/general/user/qp23/home/miniconda3/etc/profile.d/conda.sh
conda activate placeit3d
export PYTHONUNBUFFERED=1

# Verify both datasets are present and valid before starting
echo "[$(date)] Validating datasets..."
python repo/scannet/validate_hs_dataset.py \
    --dataset-roots \
        repo/scannet/completion/hs_completion_wall_v2 \
        repo/scannet/completion/hs_completion_floor_v2 \
    --splits train val

echo "[$(date)] Starting training..."
python repo/scannet/hidden_surface/train_hidden_surface_seeded.py \
    repo/scannet/hidden_surface/config_seeded_v2.json \
    --exit-after 41400

echo "[$(date)] Training complete."
