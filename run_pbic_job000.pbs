#!/bin/bash
#PBS -N pbic_job000
#PBS -l select=1:ncpus=4:mem=16gb:ngpus=1:gpu_type=RTX6000
#PBS -l walltime=01:00:00
#PBS -q v1_gpu72

set -e
cd /rds/general/user/qp23/home/Hypo3D

source /rds/general/user/qp23/home/miniconda3/etc/profile.d/conda.sh
conda activate pbic
export PYTHONUNBUFFERED=1
export LD_LIBRARY_PATH=/rds/general/user/qp23/home/miniconda3/envs/pbic/lib:$LD_LIBRARY_PATH

PY=/rds/general/user/qp23/home/miniconda3/envs/pbic/bin/python

# Clear stale lock file to prevent Chamfer 3D JIT hang
rm -f /rds/general/user/qp23/home/Hypo3D/repo/point_based_instance_completion/libs/tmp/lock

echo "[pre-check] torch + pointnet2_ops..."
$PY -c "import torch; import pointnet2_ops; print('torch', torch.__version__); print('cuda:', torch.cuda.is_available()); print('OK')"

echo "[$(date)] Running pbic on job 000 desk..."
$PY run_pbic_job000.py

echo "[$(date)] Done."
